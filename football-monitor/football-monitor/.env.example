# .env.local — NÃO versionar este arquivo (já está no .gitignore)
# Copie este arquivo para .env.local e preencha com seus valores reais.

# ── Firebase ──────────────────────────────────────────────────────────
# Cole aqui o conteúdo COMPLETO do seu serviceAccountKey.json como string JSON.
# Na Vercel: Settings → Environment Variables → adicione com o mesmo nome.
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"SEU_PROJECT_ID","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxxxx@SEU_PROJECT_ID.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}'

# ── API Football (RapidAPI) ───────────────────────────────────────────
# Obtenha em: https://rapidapi.com/api-sports/api/api-football
FOOTBALL_API_KEY=sua_chave_rapidapi_aqui

# ── Proteção do Cron ──────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
# Use para testar a rota localmente: 
#   curl -H "Authorization: Bearer SEU_SECRET" http://localhost:3000/api/sync-matches
CRON_SECRET=gere_uma_string_aleatoria_segura_aqui
